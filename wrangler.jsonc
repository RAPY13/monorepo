{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "rapyard-club-web",
	"main": ".open-next/worker.js",
	"compatibility_date": "2026-07-04",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"workers_dev": true,
	"preview_urls": false,
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"routes": [
		{
			"pattern": "rapyard.club",
			"custom_domain": true
		},
		{
			"pattern": "www.rapyard.club",
			"custom_domain": true
		}
	],
	"services": [
		{
			"binding": "WORKER_SELF_REFERENCE",
			"service": "rapyard-club-web"
		}
	],
	"observability": {
		"logs": {
			"enabled": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": false
		}
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "rapyard-db",
			"database_id": "8d4cfdf7-b02b-4de1-96f4-723380628704",
			"remote": true
		}
	]
}